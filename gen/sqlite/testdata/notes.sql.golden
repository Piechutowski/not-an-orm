-- Code generated by dbml gen sqlite from notes.dbml; DO NOT EDIT.
--
-- The blogging platform schema.
--
-- Multi-line notes keep their blank lines and become
-- paragraph breaks in godoc.

PRAGMA foreign_keys = ON;

-- A blog post. The body-form note wins over the setting-form note.
CREATE TABLE posts (
  id INTEGER PRIMARY KEY,
  -- Shown in lists and in the HTML title tag
  title TEXT NOT NULL,
  status TEXT NOT NULL CHECK (status IN ('draft', 'published', 'archived')),
  -- Raw markdown source.
  -- Rendered to HTML at publish time.
  body TEXT,
  published_at TIMESTAMP
);

CREATE TABLE tags (
  id INTEGER PRIMARY KEY NOT NULL,
  name TEXT NOT NULL UNIQUE
);
