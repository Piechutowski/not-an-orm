// closure table: every ancestor/descendant pair, including depth 0 self-pairs
Table categories {
  id int [pk]
  name varchar [not null]
}
Table category_paths [note: 'Closure table over categories'] {
  ancestor_id int [not null, ref: > categories.id]
  descendant_id int [not null, ref: > categories.id]
  depth int [not null, note: '0 for the self-pair']

  indexes {
    (ancestor_id, descendant_id) [pk]
    descendant_id
  }
}
