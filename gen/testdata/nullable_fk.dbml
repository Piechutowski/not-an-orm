// nullable vs required foreign keys and other nullable shapes
Table users {
  id bigint [pk]
}
Table posts {
  id bigint [pk]
  author_id bigint [not null, ref: > users.id]
  editor_id bigint [ref: > users.id, note: 'NULL until an editor is assigned']
  reviewed_at timestamp
  meta jsonb [note: 'nil slice expresses NULL; no pointer needed']
  raw bytea
}
