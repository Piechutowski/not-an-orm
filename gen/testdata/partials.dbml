// partial-composed tables: injected columns and notes travel; the
// table-level override of deleted_at (with its own note) wins (§6.9.4)
TablePartial timestamps {
  created_at timestamptz [not null, default: `now()`, note: 'Set on insert']
  updated_at timestamptz [note: 'NULL until first update']
}
TablePartial soft_delete {
  deleted_at timestamptz [note: 'Soft-delete marker from the partial']
}
Table invoices {
  id bigint [pk]
  total decimal(12,2) [not null]
  ~timestamps
  ~soft_delete
  deleted_at timestamptz [note: 'Override: also records who deleted, see audit log']
}
