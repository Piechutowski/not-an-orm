// analyzers: dynname
// The dynamic query layer mints package-scope Go names by concatenation
// (D29-D30): <Model>Cols for the column-handle set, <Model>Limit,
// <Model>Offset, ... for the option wrappers. Distinct declarations can
// demand the same Go name; generation refuses, this rule names both.

Table users {
  id int [pk]
}

// good: none of orders' generated names meets another declaration
Table orders {
  id int [pk]
}

// model UserLimit collides with users' generated UserLimit option wrapper
Table user_limits { //WANT dynname
  id int [pk]
}

// enum type UserOffset collides with users' UserOffset option wrapper
Enum user_offset { //WANT dynname
  fixed
}

// [model:] can also create the collision it usually fixes: this pins the
// model to users' handle-set name UserCols
Table extras [model: 'UserCols'] { //WANT dynname
  id int [pk]
}
